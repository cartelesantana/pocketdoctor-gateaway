# Gateway Configuration
PORT=3000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Google Gemini API — API key buraya girilir, frontend asla görmez
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# CORS — Hangi origin'den istek kabul edilsin?
# Geliştirme: * (herkese açık)
# Üretim: https://your-frontend-domain.com
CORS_ORIGIN=*
